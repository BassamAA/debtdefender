{
  "framework": "nextjs",
  "functions": {
    "src/app/api/generate-pdf/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/export-tracker/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/checkout/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/webhook/route.ts": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
